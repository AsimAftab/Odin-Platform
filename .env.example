# Copy to .env.local and fill in real values. Never commit .env.local.

# --- MongoDB ---
# SRV connection string from MongoDB Atlas.
# URL-encode reserved characters in the password (@ -> %40, : -> %3A, / -> %2F, # -> %23).
MONGODB_URI="mongodb+srv://<user>:<url-encoded-password>@<cluster>.mongodb.net/?appName=<app>"

# --- Better Auth (self-hosted auth) ---
# Generate a secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=replace-with-a-32-byte-hex-secret
# Base URL of the app. Locally: http://localhost:3000
# In production set to your deployed origin, e.g. https://your-app.vercel.app
BETTER_AUTH_URL=http://localhost:3000

# --- Catalog maintainers ---
# Comma-separated emails allowed to review tool requests at /dashboard/requests.
# Must match the email the account signed up with.
MAINTAINER_EMAILS=you@example.com
